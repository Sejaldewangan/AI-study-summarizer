# Server
PORT=5000
# Allowed frontend origin(s) for CORS — comma-separated for multiple
# (local dev + deployed Vercel URL). On Render, set this to your Vercel URL.
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://127.0.0.1:27017/study-platform

# JWT signing secret (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary (Dashboard > Account Details)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# NVIDIA NIM — FREE OpenAI-compatible fallback (https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Vision model for image OCR (90b = higher accuracy, slower)
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# OpenAI — optional paid fallback (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Which provider to try first: gemini | nvidia | openai (default order: gemini → nvidia → openai)
AI_PRIMARY=gemini
